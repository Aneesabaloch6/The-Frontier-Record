/* _style.tmp — Dossier theme, news-portal layout:
   trending-tags strip · centered logo · horizontal category nav · breadcrumb.
   Dark base with amber signal. Language toggled via body class. */

:root{
  --bg:#0c0e11; --panel:#08090b; --surface:#15181d;
  --topbar:#1b1e23;
  --text:#e9e7e2; --text-soft:#a6a39b; --faint:#6b6860; --line:#23262c;
  --amber:#f2a73b; --amber-bright:#ffc561; --amber-dim:rgba(242,167,59,.35);
  --wrap:74rem; --measure:42rem;
  --display:"Space Grotesk",system-ui,sans-serif;
  --body:"IBM Plex Sans",system-ui,sans-serif;
  --mono:"IBM Plex Mono",ui-monospace,monospace;
  --urdu:"Noto Nastaliq Urdu",serif;
}
*{box-sizing:border-box;}
html,body{background:var(--bg);}
body{margin:0;color:var(--text);font-family:var(--body);font-size:1.06rem;line-height:1.7;-webkit-font-smoothing:antialiased;}
a{color:var(--amber);text-decoration:none;}
a:hover{color:var(--amber-bright);}
.skip{position:absolute;width:1px;height:1px;margin:-1px;padding:0;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;}
.skip:focus{position:fixed;width:auto;height:auto;margin:0;clip:auto;top:0;inset-inline-start:0;background:var(--amber);color:#0c0e11;padding:.5rem 1rem;z-index:100;}

/* language switching */
body.lang-en [data-lang="ur"]{display:none;}
body.lang-ur [data-lang="en"]{display:none;}

/* ---------- trending tags strip ---------- */
.topbar{background:var(--topbar);border-bottom:1px solid var(--line);}
.topbar-inner{max-width:var(--wrap);margin:0 auto;display:flex;align-items:stretch;}
.topbar-label{background:var(--amber);color:#0c0e11;font-family:var(--mono);font-weight:600;
  font-size:.7rem;text-transform:uppercase;letter-spacing:.07em;padding:.5rem 1.4rem .5rem 1rem;
  display:flex;align-items:center;white-space:nowrap;
  clip-path:polygon(0 0,100% 0,calc(100% - 12px) 100%,0 100%);}
.topbar-tags{display:flex;gap:1.2rem;align-items:center;padding:.5rem 1rem;overflow-x:auto;}
.topbar-tags a{font-family:var(--mono);font-size:.71rem;color:var(--text-soft);white-space:nowrap;}
.topbar-tags a:hover{color:var(--amber);}

/* ---------- brand / logo block ---------- */
.brandbar{text-align:center;padding:2.1rem 1rem 1.5rem;}
.brand-lockup{display:inline-flex;align-items:center;gap:1rem;color:var(--text);}
.brand-lockup:hover{color:var(--text);}
.brand-emblem{width:56px;height:56px;flex:none;}
.brand-words{text-align:start;}
.brand-name{font-family:var(--display);font-weight:700;font-size:2.1rem;line-height:1;letter-spacing:.02em;text-transform:uppercase;}
.brand-name .amber{color:var(--amber);}
.brand-sub{font-family:var(--mono);font-size:.64rem;text-transform:uppercase;letter-spacing:.22em;color:var(--faint);margin-top:.55rem;}

/* ---------- nav bar ---------- */
.navbar{background:var(--panel);border-top:1px solid var(--line);border-bottom:1px solid var(--line);position:sticky;top:0;z-index:30;}
.navbar-inner{max-width:var(--wrap);margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 1rem;gap:1rem;}
.menu{display:flex;align-items:stretch;flex-wrap:wrap;}
.menu a{font-family:var(--display);font-weight:600;font-size:.8rem;text-transform:uppercase;letter-spacing:.05em;
  color:var(--text-soft);padding:.95rem 1.05rem;display:inline-block;}
.menu a:hover{color:var(--text);}
.menu a.active{color:var(--amber);box-shadow:inset 0 -3px 0 var(--amber);}
.nav-tools{display:flex;align-items:center;gap:.6rem;flex:none;}

.langtoggle{display:inline-flex;border:1px solid var(--line);border-radius:2px;overflow:hidden;}
.langtoggle button{background:transparent;color:var(--text-soft);border:0;cursor:pointer;
  padding:.32rem .8rem;font-family:var(--mono);font-size:.73rem;letter-spacing:.05em;}
.langtoggle button+button{border-inline-start:1px solid var(--line);}
.langtoggle button[aria-pressed="true"]{background:var(--amber);color:#0c0e11;}
.langtoggle button[data-langbtn="ur"]{font-family:var(--urdu);font-size:.93rem;}

/* ---------- breadcrumb ---------- */
.crumb{background:var(--amber);}
.crumb-inner{max-width:var(--wrap);margin:0 auto;padding:.55rem 1.2rem;
  font-family:var(--mono);font-size:.71rem;text-transform:uppercase;letter-spacing:.06em;color:#0c0e11;}
.crumb a{color:#0c0e11;font-weight:600;}
.crumb a:hover{text-decoration:underline;}
.crumb .sep{opacity:.55;margin:0 .5rem;}

/* ---------- content container ---------- */
.container{max-width:var(--wrap);margin:0 auto;padding:2.6rem 1.4rem 5rem;}

/* ---------- home lede ---------- */
.lede{padding-bottom:2rem;border-bottom:1px solid var(--line);margin-bottom:.5rem;}
.lede-kicker{font-family:var(--mono);font-size:.7rem;text-transform:uppercase;letter-spacing:.18em;color:var(--amber);}
.lede-title{font-family:var(--display);font-size:clamp(2rem,4vw,3rem);font-weight:700;line-height:1.04;letter-spacing:-.02em;margin:.8rem 0 .7rem;}
.lede-desc{font-size:1.15rem;color:var(--text-soft);margin:0;max-width:46rem;}

/* ---------- entries ---------- */
.entries{display:flex;flex-direction:column;}
.entry{display:grid;grid-template-columns:8.5rem 1fr;gap:1.6rem;padding:1.7rem 0;border-bottom:1px solid var(--line);}
.entry-meta{font-family:var(--mono);font-size:.71rem;text-transform:uppercase;letter-spacing:.05em;color:var(--faint);line-height:1.8;}
.entry-meta .loc{color:var(--text-soft);}
.entry-title{font-family:var(--display);font-size:1.4rem;font-weight:600;line-height:1.18;letter-spacing:-.01em;margin:0 0 .45rem;}
.entry-title a{color:var(--text);}
.entry-title a:hover{color:var(--amber);}
.entry-summary{margin:0 0 .75rem;color:var(--text-soft);font-size:1rem;line-height:1.55;}
.tags{display:flex;gap:.4rem;flex-wrap:wrap;}
.tag{font-family:var(--mono);font-size:.65rem;text-transform:uppercase;letter-spacing:.05em;color:var(--amber);
  border:1px solid var(--amber-dim);padding:.18rem .5rem;border-radius:2px;}
.tag:hover{background:var(--amber);color:#0c0e11;}
.more{margin-top:1.8rem;}
.more a{font-family:var(--mono);font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;}
.empty{font-family:var(--mono);color:var(--faint);}
.empty code{color:var(--amber-bright);}

/* ---------- listing head ---------- */
.list-head{padding-bottom:1.6rem;border-bottom:1px solid var(--line);margin-bottom:.5rem;}
.kicker{font-family:var(--mono);font-size:.7rem;text-transform:uppercase;letter-spacing:.16em;color:var(--amber);}
.list-title{font-family:var(--display);font-size:clamp(1.9rem,4vw,2.6rem);font-weight:700;letter-spacing:-.02em;margin:.6rem 0 0;}

/* ---------- document ---------- */
.doc{max-width:var(--measure);margin:0 auto;}
.doc-topics{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:1rem;}
.doc-title{font-family:var(--display);font-size:clamp(1.9rem,4vw,2.7rem);font-weight:700;line-height:1.08;letter-spacing:-.02em;margin:0 0 .9rem;}
.doc-meta{font-family:var(--mono);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;color:var(--faint);
  display:flex;gap:.55rem;align-items:center;flex-wrap:wrap;padding-bottom:1.6rem;border-bottom:1px solid var(--line);margin-bottom:2rem;}
.dot{color:var(--amber);}
.doc-body{font-size:1.12rem;line-height:1.8;}
.doc-body p{margin:0 0 1.3rem;}
.doc-body h2{font-family:var(--display);font-size:1.5rem;font-weight:600;margin:2.2rem 0 .7rem;}
.doc-body h3{font-family:var(--display);font-size:1.2rem;font-weight:600;margin:1.8rem 0 .55rem;color:var(--amber-bright);}
.doc-body a{text-decoration:underline;text-underline-offset:3px;text-decoration-color:var(--amber-dim);}
.doc-body blockquote{margin:1.6rem 0;padding:.2rem 0 .2rem 1.3rem;border-inline-start:3px solid var(--amber);color:var(--text-soft);}
.doc-body img{max-width:100%;height:auto;border:1px solid var(--line);}
.doc-body ul,.doc-body ol{padding-inline-start:1.4rem;margin:0 0 1.3rem;}
.doc-body li{margin-bottom:.5rem;}
.doc-body code{font-family:var(--mono);font-size:.85em;background:var(--surface);color:var(--amber-bright);padding:.12rem .4rem;border-radius:3px;}
.doc-body pre{background:#070809;border:1px solid var(--line);padding:1rem 1.2rem;overflow-x:auto;border-radius:4px;}
.doc-body pre code{background:none;color:var(--text);padding:0;}
.doc-body hr{border:0;border-top:1px solid var(--line);margin:2.4rem 0;}
.doc-body table{width:100%;border-collapse:collapse;margin:1.6rem 0;font-size:.95rem;}
.doc-body th,.doc-body td{border:1px solid var(--line);padding:.55rem .7rem;text-align:start;vertical-align:top;}
.doc-body thead th{background:var(--surface);font-family:var(--mono);font-size:.72rem;text-transform:uppercase;letter-spacing:.04em;color:var(--amber);}
.doc-body .admonition{background:var(--surface);border:1px solid var(--line);border-inline-start:3px solid var(--amber);padding:1rem 1.2rem;margin:1.6rem 0;border-radius:4px;}
.doc-body .admonition-title{font-family:var(--mono);font-weight:600;font-size:.74rem;text-transform:uppercase;letter-spacing:.06em;margin:0 0 .4rem;color:var(--amber);}
.sources{border-top:1px solid var(--line);margin-top:2.4rem;padding-top:1.3rem;}
.sources h2,.sources h2 *{font-family:var(--mono);font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;color:var(--faint);margin:0 0 .6rem;font-weight:500;}
.sources ol{font-size:.95rem;color:var(--text-soft);padding-inline-start:1.3rem;}
.sources li{margin-bottom:.4rem;word-break:break-word;}
.doc-foot{margin-top:2.6rem;padding-top:1.2rem;border-top:1px solid var(--line);}
.doc-foot a{font-family:var(--mono);font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;}

/* ---------- footer ---------- */
.site-foot{border-top:1px solid var(--line);background:var(--panel);margin-top:2rem;}
.site-foot-inner{max-width:var(--wrap);margin:0 auto;padding:2rem 1.4rem;display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;}
.site-foot-note{font-family:var(--mono);font-size:.66rem;color:var(--faint);max-width:30rem;line-height:1.7;}
.site-foot-copy{font-family:var(--mono);font-size:.66rem;color:var(--faint);}

/* ---------- responsive ---------- */
@media (max-width:760px){
  body{font-size:1.02rem;}
  .brand-name{font-size:1.6rem;}
  .brand-emblem{width:44px;height:44px;}
  .navbar-inner{flex-direction:column;align-items:stretch;gap:.4rem;padding:.5rem 1rem;}
  .menu{justify-content:center;}
  .menu a{padding:.6rem .7rem;}
  .nav-tools{justify-content:center;padding-bottom:.4rem;}
  .entry{grid-template-columns:1fr;gap:.5rem;}
}
