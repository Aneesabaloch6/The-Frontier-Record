/* _style.tmp — "Dossier" theme: near-black, amber signal, fixed left sidebar.
   Injected into every page by tribuilder.py. Language toggled via body class. */

:root{
  --bg:#0c0e11;          /* near-black, cool */
  --panel:#08090b;       /* sidebar */
  --surface:#15181d;     /* raised blocks (callouts, code) */
  --text:#e9e7e2;
  --text-soft:#a6a39b;
  --faint:#6b6860;
  --line:#23262c;
  --amber:#f2a73b;       /* signal accent */
  --amber-bright:#ffc561;
  --amber-dim:rgba(242,167,59,.35);
  --side:286px;
  --display:"Space Grotesk",system-ui,sans-serif;
  --body:"IBM Plex Sans",system-ui,sans-serif;
  --mono:"IBM Plex Mono",ui-monospace,monospace;
  --urdu:"Noto Nastaliq Urdu",serif;
  --measure:42rem;
}

*{box-sizing:border-box;}
html,body{background:var(--bg);}
body{margin:0;color:var(--text);font-family:var(--body);font-size:1.06rem;
     line-height:1.7;-webkit-font-smoothing:antialiased;}
a{color:var(--amber);text-decoration:none;}
a:hover{color:var(--amber-bright);}

.skip{position:absolute;width:1px;height:1px;margin:-1px;padding:0;overflow:hidden;
  clip:rect(0 0 0 0);white-space:nowrap;border:0;}
.skip:focus{position:fixed;width:auto;height:auto;margin:0;clip:auto;top:0;inset-inline-start:0;
  background:var(--amber);color:#0c0e11;padding:.5rem 1rem;z-index:100;}

/* language switching: English-first, hide inactive language */
body.lang-en [data-lang="ur"]{display:none;}
body.lang-ur [data-lang="en"]{display:none;}

/* ---------- layout ---------- */
.layout{min-height:100vh;}
.sidebar{
  position:fixed; inset-block:0; inset-inline-start:0; width:var(--side);
  background:var(--panel); border-inline-end:1px solid var(--line);
  padding:2.2rem 1.7rem; display:flex; flex-direction:column; gap:1.5rem;
  overflow-y:auto;
}
.content{
  margin-inline-start:var(--side);
  max-width:calc(var(--measure) + 9rem);
  padding:3.2rem 3.2rem 5rem;
}

/* ---------- sidebar ---------- */
.s-mark{display:block;width:30px;height:4px;background:var(--amber);border-radius:2px;margin-bottom:1.1rem;}
.brand-link{display:block;color:var(--text);}
.brand-link:hover{color:var(--text);}
.s-brand-title{font-family:var(--display);font-weight:700;font-size:1.42rem;line-height:1.08;letter-spacing:-.01em;}
.s-brand-tag{font-family:var(--mono);font-size:.66rem;text-transform:uppercase;
  letter-spacing:.1em;color:var(--faint);margin-top:.7rem;line-height:1.6;}

.langtoggle{display:inline-flex;border:1px solid var(--line);border-radius:2px;overflow:hidden;width:fit-content;}
.langtoggle button{background:transparent;color:var(--text-soft);border:0;cursor:pointer;
  padding:.34rem .85rem;font-family:var(--mono);font-size:.74rem;letter-spacing:.05em;}
.langtoggle button+button{border-inline-start:1px solid var(--line);}
.langtoggle button[aria-pressed="true"]{background:var(--amber);color:#0c0e11;}
.langtoggle button[data-langbtn="ur"]{font-family:var(--urdu);font-size:.95rem;}

.s-nav{display:flex;flex-direction:column;}
.s-nav a{font-family:var(--mono);font-size:.78rem;text-transform:uppercase;letter-spacing:.07em;
  color:var(--text-soft);padding:.46rem 0;border-bottom:1px solid var(--line);}
.s-nav a:hover{color:var(--text);}
.s-nav a.active{color:var(--amber);}
.s-nav a.active::before{content:"\203A\00a0\00a0";color:var(--amber);}
.s-heading{font-family:var(--mono);font-size:.62rem;text-transform:uppercase;
  letter-spacing:.2em;color:var(--faint);margin-bottom:.2rem;}
.s-topics a{border-bottom:1px solid transparent;padding:.34rem 0;font-size:.74rem;letter-spacing:.05em;}
.s-foot{margin-top:auto;padding-top:1.4rem;border-top:1px solid var(--line);}
.s-foot-note{font-family:var(--mono);font-size:.64rem;line-height:1.7;color:var(--faint);}
.s-foot-copy{font-family:var(--mono);font-size:.62rem;color:var(--faint);margin-top:.7rem;}

/* ---------- home lede ---------- */
.lede{padding-bottom:2.2rem;border-bottom:1px solid var(--line);margin-bottom:.5rem;}
.lede-kicker{font-family:var(--mono);font-size:.7rem;text-transform:uppercase;letter-spacing:.18em;color:var(--amber);}
.lede-title{font-family:var(--display);font-size:clamp(2rem,4vw,3rem);font-weight:700;
  line-height:1.04;letter-spacing:-.02em;margin:.8rem 0 .7rem;color:var(--text);}
.lede-desc{font-size:1.15rem;color:var(--text-soft);margin:0;max-width:42rem;}

/* ---------- entry list ---------- */
.entries{display:flex;flex-direction:column;}
.entry{display:grid;grid-template-columns:8.5rem 1fr;gap:1.6rem;
  padding:1.7rem 0;border-bottom:1px solid var(--line);}
.entry-meta{font-family:var(--mono);font-size:.71rem;text-transform:uppercase;
  letter-spacing:.05em;color:var(--faint);line-height:1.8;}
.entry-meta .loc{color:var(--text-soft);}
.entry-title{font-family:var(--display);font-size:1.4rem;font-weight:600;line-height:1.18;
  letter-spacing:-.01em;margin:0 0 .45rem;}
.entry-title a{color:var(--text);}
.entry-title a:hover{color:var(--amber);}
.entry-summary{margin:0 0 .75rem;color:var(--text-soft);font-size:1rem;line-height:1.55;}

.tags{display:flex;gap:.4rem;flex-wrap:wrap;}
.tag{font-family:var(--mono);font-size:.65rem;text-transform:uppercase;letter-spacing:.05em;
  color:var(--amber);border:1px solid var(--amber-dim);padding:.18rem .5rem;border-radius:2px;}
.tag:hover{background:var(--amber);color:#0c0e11;}

.more{margin-top:1.8rem;}
.more a{font-family:var(--mono);font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;}
.empty{font-family:var(--mono);color:var(--faint);}
.empty code{color:var(--amber-bright);}

/* ---------- listing head ---------- */
.list-head{padding-bottom:1.6rem;border-bottom:1px solid var(--line);margin-bottom:.5rem;}
.kicker{font-family:var(--mono);font-size:.7rem;text-transform:uppercase;letter-spacing:.16em;color:var(--amber);}
.list-title{font-family:var(--display);font-size:clamp(1.9rem,4vw,2.6rem);font-weight:700;
  letter-spacing:-.02em;margin:.6rem 0 0;color:var(--text);}

/* ---------- document ---------- */
.doc{max-width:var(--measure);}
.doc-topics{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:1rem;}
.doc-title{font-family:var(--display);font-size:clamp(1.9rem,4vw,2.7rem);font-weight:700;
  line-height:1.08;letter-spacing:-.02em;margin:0 0 .9rem;color:var(--text);}
.doc-meta{font-family:var(--mono);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;
  color:var(--faint);display:flex;gap:.55rem;align-items:center;flex-wrap:wrap;
  padding-bottom:1.6rem;border-bottom:1px solid var(--line);margin-bottom:2rem;}
.dot{color:var(--amber);}
.doc-body{font-size:1.12rem;line-height:1.8;}
.doc-body p{margin:0 0 1.3rem;}
.doc-body h2{font-family:var(--display);font-size:1.5rem;font-weight:600;margin:2.2rem 0 .7rem;color:var(--text);}
.doc-body h3{font-family:var(--display);font-size:1.2rem;font-weight:600;margin:1.8rem 0 .55rem;color:var(--text);}
.doc-body a{text-decoration:underline;text-underline-offset:3px;text-decoration-color:var(--amber-dim);}
.doc-body blockquote{margin:1.6rem 0;padding:.2rem 0 .2rem 1.3rem;border-inline-start:3px solid var(--amber);color:var(--text-soft);}
.doc-body img{max-width:100%;height:auto;border:1px solid var(--line);}
.doc-body ul,.doc-body ol{padding-inline-start:1.4rem;margin:0 0 1.3rem;}
.doc-body li{margin-bottom:.5rem;}
.doc-body code{font-family:var(--mono);font-size:.85em;background:var(--surface);color:var(--amber-bright);padding:.12rem .4rem;border-radius:3px;}
.doc-body pre{background:#070809;border:1px solid var(--line);padding:1rem 1.2rem;overflow-x:auto;border-radius:4px;}
.doc-body pre code{background:none;color:var(--text);padding:0;}
.doc-body hr{border:0;border-top:1px solid var(--line);margin:2.4rem 0;}
.doc-body table{width:100%;border-collapse:collapse;margin:1.6rem 0;font-size:.95rem;}
.doc-body th,.doc-body td{border:1px solid var(--line);padding:.55rem .7rem;text-align:start;vertical-align:top;}
.doc-body thead th{background:var(--surface);font-family:var(--mono);font-size:.72rem;text-transform:uppercase;letter-spacing:.04em;color:var(--amber);}
.doc-body .admonition{background:var(--surface);border:1px solid var(--line);border-inline-start:3px solid var(--amber);padding:1rem 1.2rem;margin:1.6rem 0;border-radius:4px;}
.doc-body .admonition-title{font-family:var(--mono);font-weight:600;font-size:.74rem;text-transform:uppercase;letter-spacing:.06em;margin:0 0 .4rem;color:var(--amber);}

.sources{border-top:1px solid var(--line);margin-top:2.4rem;padding-top:1.3rem;}
.sources h2,.sources h2 *{font-family:var(--mono);font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;color:var(--faint);margin:0 0 .6rem;font-weight:500;}
.sources ol{font-size:.95rem;color:var(--text-soft);padding-inline-start:1.3rem;}
.sources li{margin-bottom:.4rem;word-break:break-word;}
.doc-foot{margin-top:2.6rem;padding-top:1.2rem;border-top:1px solid var(--line);}
.doc-foot a{font-family:var(--mono);font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;}

/* ---------- responsive: sidebar becomes a top bar ---------- */
@media (max-width:880px){
  .sidebar{position:static;width:auto;inset:auto;border-inline-end:0;
    border-bottom:1px solid var(--line);padding:1.5rem 1.3rem;gap:1.1rem;}
  .content{margin-inline-start:0;padding:2.2rem 1.3rem 4rem;}
  .s-mark{margin-bottom:.7rem;}
  .s-nav{flex-direction:row;flex-wrap:wrap;gap:.1rem 1.3rem;}
  .s-nav a{border-bottom:0;padding:.2rem 0;}
  .s-nav a.active::before{content:"";}
  .s-foot{display:none;}
  .entry{grid-template-columns:1fr;gap:.5rem;}
}
